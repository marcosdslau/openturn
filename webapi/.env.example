# Ambiente OpenTurn (serviços Windows: sufixo do nome do serviço). Valores: PRD | DEV
NODE_ENV=DEV
# Prefixo de isolamento para filas RabbitMQ e chaves/canais Redis (DEV | PRD).
# Se omitido, é derivado de NODE_ENV (DEV/development/test → DEV; production/PRD → PRD).
# Obrigatório quando múltiplas instâncias compartilham o mesmo broker/Redis.
# OPENTURN_DEPLOYMENT_PREFIX=DEV

# Em dev ou PostgreSQL com max_connections baixo, limite o pool do Prisma, ex.:
# postgresql://user:pass@host:5432/db?schema=public&connection_limit=3
DATABASE_URL="postgresql://user:password@localhost:5432/openturn_db?schema=public"
JWT_SECRET="your-secret-key"
PORT=8000
PORTWS=8001

# URL base da própria API (com /api), usada para disparar webhooks de rotina a partir do monitor ControlID
# Ex.: https://staging.schoolguard.com.br/api
API_URL=

# Redis (console, realtime e cache)
REDIS_HOST=localhost
REDIS_PORT=6379
# Opcionais (Redis 6+ ACL). Senhas com caracteres especiais: use aspas, ex.: REDIS_PASSWORD="sua*senha"
REDIS_USERNAME=
REDIS_PASSWORD=
# ACL: ~* = chaves; &* = canais pub/sub (obrigatório para BullMQ, rotina:console, adapter Socket.IO). Sem &* aparece NOPERM no subscribe.
# redis-cli -u redis://127.0.0.1:6379 -a '(sua-adminpass)' ACL SETUSER openturn on >openturn_secret ~* &* +@all -@dangerous
# Depois use REDIS_USERNAME=openturn REDIS_PASSWORD=openturn_secret

# Monitor global (snapshot Redis): fuso para buckets das séries; cron usa MONITOR_CRON_TZ (ex. America/Sao_Paulo)
MONITOR_SNAPSHOT_TZ=America/Sao_Paulo
MONITOR_CRON_TZ=America/Sao_Paulo

# Limites de execução
ROTINA_MAX_CONCURRENT_MANUAL=10
# TTL do marcador Redis rotina:pending:{exeId} após enqueue (UX; worker remove ao consumir)
ROTINA_PENDING_TTL_SEC=86400

# RabbitMQ (orquestração de jobs por instituição)
RABBIT_URL=amqp://guest:guest@localhost:5672
RABBIT_MGMT_URL=http://localhost:15672
RABBIT_MGMT_USER=guest
RABBIT_MGMT_PASS=guest

# OpenAI (módulo IA)
OPENAI_API_KEY=sk-...

# Remote Gateway
REMOTE_GATEWAY_URL=https://staging.schoolguard.com.br
RELAY_INTERNAL_TOKEN=openturn-internal-secret-token

# Recuperação de senha (Brevo) — APP_URL = URL pública do frontend (Next.js), sem barra final
BREVO_API_KEY=
APP_URL=https://staging.schoolguard.com.br
EMAIL_FROM=noreply@schoolguard.com.br
EMAIL_FROM_NAME=SchoolGuard
