generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

enum GrupoAcesso {
  SUPER_ROOT
  SUPER_ADMIN
  ADMIN
  GESTOR
  OPERACAO
}

enum AcaoPassagem {
  ENTRADA
  SAIDA
}

enum RPDStatus {
  ENVIADO
  ERRO
  MANUAL
  PENDENTE
}

enum TipoAglutinacaoRegistro {
  tempo_permanencia
  tempo_permanencia_periodo
  entrada_saida
}

// === ADDON ON-PREMISE CONNECTOR ===

enum ConnectorStatus {
  ONLINE
  OFFLINE
  PAIRING
}

enum SessaoStatus {
  ATIVA
  EXPIRADA
  ENCERRADA
}

model CLICliente {
  CLICodigo     Int              @id @default(autoincrement())
  CLINome       String
  CLIDocumento  String?          @unique
  CLIAtivo      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  instituicoes  INSInstituicao[]
  acessos       USRAcesso[]
  conconnectors CONConnector[]
}

model INSInstituicao {
  INSCodigo           Int                   @id @default(autoincrement())
  CLICodigo           Int
  cliente             CLICliente            @relation(fields: [CLICodigo], references: [CLICodigo])
  INSNome             String
  INSCodigoExterno    String?
  INSAtivo            Boolean               @default(true)
  INSLogsAutoExcluir  Boolean               @default(true)
  INSLogsDiasRetencao Int                   @default(90)
  INSMaxExecucoesSimultaneas Int            @default(8)
  INSWorkerAtivo      Boolean               @default(true) // false = worker não consome fila desta instituição
  /// Offset UTC em horas (ex.: -3). Usado ao persistir ControlID notifyTime a partir de body.time bruto.
  INSFusoHorario      Int                   @default(-3)
  /// Tolerância em minutos (entrada) — janela em relação ao horário de referência.
  INSToleranciaEntradaMinutos Int         @default(15)
  /// Tolerância em minutos (saída) — janela em relação ao horário de referência.
  INSToleranciaSaidaMinutos   Int         @default(15)
  /// Limiar facial padrão (0–1000) para reconhecimento quando não houver valor na pessoa.
  INSTLimiarFacialDefault     Int         @default(680)
  INSConfigHardware Json? // Global hardware config (e.g. ControlID Monitor IP/Port)
  INSControlidMonitorRotinaAtiva    Boolean @default(false)
  INSControlidMonitorRotinaCodigo   Int?
  controlidMonitorRotina            ROTRotina?            @relation("InstituicaoControlidMonitorRotina", fields: [INSControlidMonitorRotinaCodigo], references: [ROTCodigo], onDelete: SetNull)
  /// Rotina WEBHOOK opcional: "Sincronizar todos" nos equipamentos enfileira uma execução por pessoa ativa em vez do sync físico.
  INSRotinaPessoasCodigo            Int?
  rotinaPessoasWebhook              ROTRotina?            @relation("InstituicaoRotinaPessoasWebhook", fields: [INSRotinaPessoasCodigo], references: [ROTCodigo], onDelete: SetNull)
  /// Expressão cron (node-cron, 6 campos: sec min hour dom month dow) para agendamento da sincronização de registros diários.
  INSTempoSync                      String  @default("0 0 9,15,22 * * *")
  /// Indica se a sincronização automática de registros diários está ativa para esta instituição.
  INSSyncRegistrosDiarios           Boolean @default(false)
  /// Modo de agregação de passagens em registros diários (RPD).
  INSAglutinacaoRegistros           TipoAglutinacaoRegistro @default(entrada_saida)
  /// Se true, a rotina preenche entrada/saída ausentes quando o período já encerrou.
  INSAglutinacaoAutoCompletePeriodo Boolean                 @default(false)
  /// Indica se a sincronização agendada de frequências ao ERP educacional está ativa.
  INSSyncFreqEducacional            Boolean @default(false)
  /// Expressão cron (5 campos: min hora dom mês dow) para sincronização de frequências ao ERP.
  INSTempoFreqEducacional           String  @default("58 23 * * *")
  INSLancFreqAusenciaRegistro       Boolean @default(false)
  createdAt                         DateTime              @default(now())
  pessoas             PESPessoa[]
  matriculas          MATMatricula[]
  equipamentos        EQPEquipamento[]
  erpConfig           ERPConfiguracao[]
  acessos             USRAcesso[]
  passagens           REGRegistroPassagem[]
  registrosDiarios    RPDRegistrosDiarios[]
  cmdcomandoFilas     CMDComandoFila[]
  rotrotinas          ROTRotina[]
  rotexecucaoLogs     ROTExecucaoLog[]
  connector           CONConnector?
  sessoesRemotas      RMTSessaoRemota[]
  permissoesIa        AIPEPermissaoIa[]
  conversasIa         AICConversaIa[]
  mensagensIa         AIMSMensagemIa[]
  creditosIa          AILCreditoLedger[]
  ctlControlidDaos    CTLControlidDao[]
  ctlControlidCatraEvents CTLControlidCatraEvent[]
  periodosRegistro        PERPeriodosConfig[]
  notificacoes        NOTNotificacao[]
}

model PESPessoa {
  PESCodigo            Int                   @id @default(autoincrement())
  PESIdExterno         String?
  PESNome              String
  PESNomeSocial        String?
  PESDocumento         String?
  PESEmail             String?
  PESTelefone          String?
  PESCelular           String?
  PESFotoBase64        String?
  PESFotoExtensao      String?
  PESImageError        Json?
  PESGrupo             String?
  PESCartaoTag         String?
  PESTemplates         Json?
  PESAtivo             Boolean               @default(true)
  PESLimiarFacial      Int                   @default(680)
  PESGemeo             Boolean               @default(false)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao        @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  deletedAt            DateTime?
  matriculas           MATMatricula[]
  passagens            REGRegistroPassagem[]
  registrosDiarios     RPDRegistrosDiarios[]
  mapeamentos          PESEquipamentoMapeamento[]
}

model NOTNotificacao {
  NOTCodigo            Int            @id @default(autoincrement())
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo], onDelete: Cascade)
  ckey                 String         @unique
  tipo                 String
  titulo               String
  conteudo             String
  origem               String
  chaveOrigem          String
  lido                 Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([INSInstituicaoCodigo, lido, updatedAt])
}

model MATMatricula {
  MATCodigo            Int            @id @default(autoincrement())
  PESCodigo            Int
  pessoa               PESPessoa      @relation(fields: [PESCodigo], references: [PESCodigo])
  MATNumero            String
  MATCurso             String?
  MATSerie             String?
  MATTurma             String?
  MATAtivo             Boolean        @default(true)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
}

model EQPEquipamento {
  EQPCodigo            Int                   @id @default(autoincrement())
  EQPDescricao         String?
  EQPMarca             String?
  EQPModelo            String?
  EQPEnderecoIp        String?
  /// ID do dispositivo no Monitor ControlID (nuvem); coluna dedicada (espelha ou substitui deviceId em EQPConfig quando único)
  deviceId             String?               @map("EQPDeviceId")
  EQPConfig            Json?
  EQPUltimoSincronismo DateTime?
  EQPUsaAddon          Boolean               @default(false)
  EQPAtivo             Boolean               @default(true)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao        @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime              @default(now())
  passagens            REGRegistroPassagem[]
  cmdcomandoFilas      CMDComandoFila[]
  sessoesRemotas       RMTSessaoRemota[]
  mapeamentos          PESEquipamentoMapeamento[]
}

model ERPConfiguracao {
  ERPCodigo            Int            @id @default(autoincrement())
  ERPSistema           String
  ERPUrlBase           String?
  ERPToken             String?
  ERPConfigJson        Json?
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
}

model USRUsuario {
  USRCodigo Int     @id @default(autoincrement())
  USRNome   String
  USREmail  String  @unique
  USRSenha  String
  USRAtivo  Boolean @default(true)

  // Profile fields
  USRTelefone String?
  USRBio      String?
  USRFotoUrl  String?

  // Social links
  USRFacebook  String?
  USRTwitter   String?
  USRLinkedin  String?
  USRInstagram String?

  // Address information
  USRPais   String?
  USRCidade String?
  USREstado String?
  USRCep    String?
  USRTaxId  String?

  createdAt           DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  acessos             USRAcesso[]
  rotrotinas          ROTRotina[]
  rothistoricoVersaos ROTHistoricoVersao[]
  sessoesRemotas      RMTSessaoRemota[]
  permissoesIa        AIPEPermissaoIa[]
  conversasIa         AICConversaIa[]
  creditosIa          AILCreditoLedger[]
  senhaResetTokens    USRSenhaResetToken[]
  rpdCriados          RPDRegistrosDiarios[] @relation("RpdCriacao")
  rpdAlterados        RPDRegistrosDiarios[] @relation("RpdAlteracao")
}

model USRSenhaResetToken {
  USRSTCodigo       Int        @id @default(autoincrement())
  USRCodigo         Int
  usuario           USRUsuario @relation(fields: [USRCodigo], references: [USRCodigo], onDelete: Cascade)
  USRTokenHash      String     @unique
  USRTokenExpiresAt DateTime
  createdAt         DateTime   @default(now())

  @@index([USRCodigo])
}

model PESEquipamentoMapeamento {
  PEQCodigo            Int            @id @default(autoincrement())
  PESCodigo            Int
  pessoa               PESPessoa      @relation(fields: [PESCodigo], references: [PESCodigo], onDelete: Cascade)
  EQPCodigo            Int
  equipamento          EQPEquipamento @relation(fields: [EQPCodigo], references: [EQPCodigo], onDelete: Cascade)
  PEQIdNoEquipamento   String         // ID no hardware (ex: "100")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([PESCodigo, EQPCodigo])
  @@unique([EQPCodigo, PEQIdNoEquipamento])
}

model USRAcesso {
  UACCodigo            Int             @id @default(autoincrement())
  USRCodigo            Int
  usuario              USRUsuario      @relation(fields: [USRCodigo], references: [USRCodigo], onDelete: Cascade)
  grupo                GrupoAcesso
  CLICodigo            Int?
  cliente              CLICliente?     @relation(fields: [CLICodigo], references: [CLICodigo])
  INSInstituicaoCodigo Int?
  instituicao          INSInstituicao? @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime        @default(now())

  @@unique([USRCodigo, grupo, CLICodigo, INSInstituicaoCodigo])
}

model REGRegistroPassagem {
  REGCodigo            Int            @id @default(autoincrement())
  PESCodigo            Int
  pessoa               PESPessoa      @relation(fields: [PESCodigo], references: [PESCodigo])
  REGAcao              AcaoPassagem
  EQPCodigo            Int
  equipamento          EQPEquipamento @relation(fields: [EQPCodigo], references: [EQPCodigo])
  REGTimestamp         BigInt
  REGDataHora          DateTime
  /// Indica se este registro já foi processado e agrupado em RPDRegistrosDiarios.
  REGProcessado        Boolean        @default(false)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())

  @@index([INSInstituicaoCodigo, REGProcessado])
}

model PERPeriodosConfig {
  PERCodigo                   Int                   @id @default(autoincrement())
  PERNome                     String
  /// Horário local da instituição, formato "HH:mm" (24h).
  PERHorarioInicio            String
  PERHorarioFim               String
  /// Minutos antes do início em que entradas entram no período.
  PERToleranciaEntradaMinutos Int                   @default(0)
  /// Minutos após o fim em que saídas entram no período.
  PERToleranciaSaidaMinutos   Int                   @default(0)
  INSInstituicaoCodigo        Int
  instituicao                 INSInstituicao        @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo], onDelete: Cascade)
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  registrosDiarios            RPDRegistrosDiarios[]

  @@unique([INSInstituicaoCodigo, PERNome])
  @@index([INSInstituicaoCodigo])
}

model RPDRegistrosDiarios {
  RPDCodigo            Int                @id @default(autoincrement())
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao     @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  /// Data do registro (sem hora — armazenado como meia-noite UTC; exibição usa INSFusoHorario).
  RPDData              DateTime           @db.Date
  PESCodigo            Int
  pessoa               PESPessoa          @relation(fields: [PESCodigo], references: [PESCodigo])
  /// Índice da janela no dia (1..N). Modo entrada_saida usa sempre 1.
  RPDJanelaIndice      Int                @default(1)
  /// Período de origem (modo tempo_permanencia_periodo). Null = janela extra ou modo sem período.
  PERCodigo            Int?
  periodo              PERPeriodosConfig? @relation(fields: [PERCodigo], references: [PERCodigo], onDelete: SetNull)
  RPDDataEntrada       DateTime?
  RPDDataSaida         DateTime?
  RPDStatus            RPDStatus          @default(PENDENTE)
  RPDResult            Json?
  /// Resposta da API Gennera em caso de falha (null em sucesso).
  RPDResponseRequest   Json?
  /// Usuário responsável pela criação manual (null = gerado pelo worker).
  USRCodigoCriacao     Int?
  usuarioCriacao       USRUsuario?        @relation("RpdCriacao", fields: [USRCodigoCriacao], references: [USRCodigo], onDelete: SetNull)
  /// Usuário que realizou a última alteração manual.
  USRCodigoAlteracao   Int?
  usuarioAlteracao     USRUsuario?        @relation("RpdAlteracao", fields: [USRCodigoAlteracao], references: [USRCodigo], onDelete: SetNull)
  RPDAlteradoEm        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([INSInstituicaoCodigo, PESCodigo, RPDData, RPDJanelaIndice])
  @@index([INSInstituicaoCodigo, RPDData])
}

enum StatusComando {
  PENDENTE
  ENVIADO
  EXECUTADO
  ERRO
}

model CMDComandoFila {
  CMDCodigo            Int            @id @default(autoincrement())
  EQPCodigo            Int
  equipamento          EQPEquipamento @relation(fields: [EQPCodigo], references: [EQPCodigo])
  CMDVerb              String         @default("POST")
  CMDEndpoint          String
  CMDBody              Json?
  CMDContentType       String         @default("application/json")
  CMDStatus            StatusComando  @default(PENDENTE)
  CMDResultado         Json?
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model CTLControlidDao {
  CTDCodigo                    Int            @id @default(autoincrement())
  INSInstituicaoCodigo         Int
  instituicao                  INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo], onDelete: Cascade)
  deviceId                     String         @map("device_id")
  /// Valor bruto de body.time do webhook (chave estável com instituição + deviceId).
  originTime                   BigInt         @map("origin_time")
  /// Instantâneo ajustado pelo INSFusoHorario da instituição no momento do ingest.
  notifyTime                   BigInt         @map("time")
  ctlObject                    String         @map("object")
  changeType                   String         @map("type")
  valuesId                     String?        @map("values_id")
  valuesTime                   String?        @map("values_time")
  valuesEvent                  String?        @map("values_event")
  valuesDeviceId               String?        @map("values_device_id")
  valuesIdentifierId           String?        @map("values_identifier_id")
  valuesUserId                 String?        @map("values_user_id")
  valuesPortalId               String?        @map("values_portal_id")
  valuesIdentificationRuleId   String?        @map("values_identification_rule_id")
  valuesCardValue              String?        @map("values_card_value")
  valuesQrcodeValue            String?        @map("values_qrcode_value")
  valuesPinValue               String?        @map("values_pin_value")
  valuesConfidence             String?        @map("values_confidence")
  valuesMask                   String?        @map("values_mask")
  valuesLogTypeId              String?        @map("values_log_type_id")
  processed                    Boolean        @default(false) @map("processed")
  createdAt                    DateTime       @default(now())

  @@index([INSInstituicaoCodigo, processed])
  @@index([INSInstituicaoCodigo, deviceId, originTime])
  @@index([INSInstituicaoCodigo, deviceId, notifyTime])
  @@map("controlid_dao")
}

model CTLControlidCatraEvent {
  CTCCodigo            Int            @id @default(autoincrement())
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo], onDelete: Cascade)
  deviceId             String         @map("device_id")
  originTime           BigInt         @map("origin_time")
  notifyTime           BigInt         @map("time")
  accessEventId        String         @map("access_event_id")
  eventType            String         @map("event_type")
  eventName            String?        @map("event_name")
  eventTime            BigInt?        @map("event_time")
  eventUuid            String?        @map("event_uuid")
  processed            Boolean        @default(false) @map("processed")
  createdAt            DateTime       @default(now())

  @@index([INSInstituicaoCodigo, processed])
  @@index([INSInstituicaoCodigo, deviceId, originTime])
  @@index([INSInstituicaoCodigo, deviceId, notifyTime])
  @@map("controlid_catra_event")
}

// === EXECUTION ENGINE: Rotinas Dinâmicas ===

enum TipoRotina {
  SCHEDULE
  WEBHOOK
}

enum WebhookTokenSource {
  HEADER
  QUERY
}

enum HttpMetodo {
  GET
  POST
  PUT
  PATCH
}

enum StatusExecucao {
  EM_EXECUCAO
  SUCESSO
  ERRO
  TIMEOUT
  CANCELADO
}

model ROTRotina {
  ROTCodigo             Int                  @id @default(autoincrement())
  ROTNome               String
  ROTDescricao          String?
  ROTTipo               TipoRotina
  ROTCronExpressao      String?
  ROTWebhookPath        String?
  ROTWebhookMetodo      HttpMetodo?
  ROTWebhookAguardar    Boolean              @default(false)
  ROTWebhookSeguro      Boolean              @default(true)
  ROTWebhookTokenSource WebhookTokenSource?  @default(HEADER)
  ROTWebhookTokenKey    String?              @default("x-webhook-token")
  ROTWebhookToken       String?
  ROTCodigoJS           String
  ROTAtivo              Boolean              @default(true)
  ROTPermiteParalelismo Boolean              @default(true)
  ROTTimeoutSeconds     Int                  @default(30)
  ROTUltimaExecucao     DateTime?
  INSInstituicaoCodigo Int
  instituicao           INSInstituicao       @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  instituicoesControlidMonitor INSInstituicao[] @relation("InstituicaoControlidMonitorRotina")
  instituicoesRotinaPessoasWebhook INSInstituicao[] @relation("InstituicaoRotinaPessoasWebhook")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  createdBy             Int
  criador               USRUsuario           @relation(fields: [createdBy], references: [USRCodigo])
  execucoes             ROTExecucaoLog[]
  versoes               ROTHistoricoVersao[]
  conversasIa           AICConversaIa[]

  // @@unique constraint removed (handled in service layer)
}

model ROTExecucaoLog {
  EXECodigo            Int            @id @default(autoincrement())
  EXEIdExterno         String         @unique @default(uuid())
  ROTCodigo            Int?
  rotina               ROTRotina?     @relation(fields: [ROTCodigo], references: [ROTCodigo])
  EXEStatus            StatusExecucao
  EXEInicio            DateTime
  EXEFim               DateTime?
  EXEDuracaoMs         Int?
  EXEResultado         Json?
  EXEErro              String?
  EXELogs              Json?
  EXETrigger           String
  EXERequestBody       Json?
  EXERequestParams     Json?
  EXERequestPath       String?
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
}

model ROTHistoricoVersao {
  HVICodigo     Int        @id @default(autoincrement())
  ROTCodigo     Int
  rotina        ROTRotina  @relation(fields: [ROTCodigo], references: [ROTCodigo])
  HVICodigoJS   String
  HVIObservacao String?
  createdBy     Int
  criador       USRUsuario @relation(fields: [createdBy], references: [USRCodigo])
  createdAt     DateTime   @default(now())
}

// === ADDON: Connector & Remote Sessions ===

model CONConnector {
  CONCodigo            Int               @id @default(autoincrement())
  CONNome              String
  CONToken             String            @unique
  CONStatus            ConnectorStatus   @default(OFFLINE)
  CONUltimoHeartbeat   DateTime?
  CONVersao            String?
  CONMetadata          Json?
  CLICodigo            Int
  cliente              CLICliente        @relation(fields: [CLICodigo], references: [CLICodigo])
  INSInstituicaoCodigo Int               @unique
  instituicao          INSInstituicao    @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  sessoesRemotas       RMTSessaoRemota[]
}

model RMTSessaoRemota {
  RMTCodigo            Int            @id @default(autoincrement())
  RMTSessionId         String         @unique @default(uuid())
  EQPCodigo            Int
  equipamento          EQPEquipamento @relation(fields: [EQPCodigo], references: [EQPCodigo])
  CONCodigo            Int
  connector            CONConnector   @relation(fields: [CONCodigo], references: [CONCodigo])
  USRCodigo            Int
  usuario              USRUsuario     @relation(fields: [USRCodigo], references: [USRCodigo])
  RMTTargetIp          String?
  RMTStatus            SessaoStatus   @default(ATIVA)
  RMTExpiraEm          DateTime
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

// === MVP IA ASSISTANT ===

// Global - Provedores habilitados na plataforma
model AIPProvedorIa {
  AIPCodigo   Int      @id @default(autoincrement())
  AIPNome     String   // ex: "OpenAI", "Anthropic"
  AIPAtivo    Boolean  @default(true)
  modelos     AIMModeloIa[]
}

// Global - Tabela de preços por modelo
model AIMModeloIa {
  AIMCodigo            Int      @id @default(autoincrement())
  AIPCodigo            Int
  provedor             AIPProvedorIa @relation(fields: [AIPCodigo], references: [AIPCodigo])
  AIMNome              String   // ex: "gpt-4-turbo", "gpt-3.5-turbo"
  AIMProviderModelId   String   // ID do modelo na API de destino via provedor
  AIMCustoInput1k      Float    // Custo a cada 1000 tokens de entrada (em USD)
  AIMCustoOutput1k     Float    // Custo a cada 1000 tokens de saída (em USD)
  AIMMaxTokens         Int      // Limite de contexto do modelo (ex: 128000)
  AIMAtivo             Boolean  @default(true)
  conversas            AICConversaIa[]
  creditosLedger       AILCreditoLedger[]
}

// Tenant - Regras de Permissões e Cotas por Instituição/Usuário
model AIPEPermissaoIa {
  AIPECodigo           Int            @id @default(autoincrement())
  USRCodigo            Int
  usuario              USRUsuario     @relation(fields: [USRCodigo], references: [USRCodigo], onDelete: Cascade)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  
  AIPEHabilitado       Boolean        @default(false)
  AIPEModelosPermitidos String?       // Array de IDs permitidos em JSON (referência AIMCodigo)
  AIPELimiteTokensDia  Int            @default(100000) // Cota diária do plano atual
  createdAt            DateTime       @default(now())

  @@unique([USRCodigo, INSInstituicaoCodigo])
}

// Tenant - Conversas (Agrupamento dos históricos)
model AICConversaIa {
  AICCodigo            Int            @id @default(autoincrement())
  AICTitulo            String
  USRCodigo            Int
  usuario              USRUsuario     @relation(fields: [USRCodigo], references: [USRCodigo], onDelete: Cascade)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  ROTCodigo            Int?           
  rotina               ROTRotina?     @relation(fields: [ROTCodigo], references: [ROTCodigo], onDelete: Cascade)
  AIMCodigo            Int
  modelo               AIMModeloIa    @relation(fields: [AIMCodigo], references: [AIMCodigo])
  
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?      
  mensagens            AIMSMensagemIa[]
}

// Tenant - Mensagens Individuais e Consumo
model AIMSMensagemIa {
  AIMSCodigo           Int            @id @default(autoincrement())
  AICCodigo            Int
  conversa             AICConversaIa  @relation(fields: [AICCodigo], references: [AICCodigo], onDelete: Cascade)
  
  AIMSRole             String         // "user", "assistant", "system"
  AIMSContent          String         // Texto da conversa JSON array
  AIMSIsContextFile    Boolean        @default(false) // Se for apenas config anexado contextual
  
  AIMSInputTokens      Int            @default(0)
  AIMSOutputTokens     Int            @default(0)
  AIMSCostUsd          Float          @default(0.0)
  
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  createdAt            DateTime       @default(now())
}

// Tenant - Tabela Contábil de Uso
model AILCreditoLedger {
  AILCodigo            Int            @id @default(autoincrement())
  USRCodigo            Int
  usuario              USRUsuario     @relation(fields: [USRCodigo], references: [USRCodigo], onDelete: Cascade)
  INSInstituicaoCodigo Int
  instituicao          INSInstituicao @relation(fields: [INSInstituicaoCodigo], references: [INSCodigo])
  
  AILTipoLog           String         // "DEBIT_CONSUMO", "CREDIT_COMPRA"
  AILTokensInput       Int            @default(0)
  AILTokensOutput      Int            @default(0)
  AIMCodigo            Int?
  modelo               AIMModeloIa?   @relation(fields: [AIMCodigo], references: [AIMCodigo])
  
  AILValorUsd          Float          // Positivo se Custo (Débito da cota). Negativo se crédito.
  createdAt            DateTime       @default(now())
}
