# Ambiente OpenTurn (serviços Windows: sufixo do nome do serviço). Valores: PRD | DEV
NODE_ENV=DEV
# Prefixo de isolamento para filas RabbitMQ e chaves/canais Redis (DEV | PRD).
# Se omitido, é derivado de NODE_ENV (DEV/development/test → DEV; production/PRD → PRD).
# Obrigatório quando múltiplas instâncias compartilham o mesmo broker/Redis.
# OPENTURN_DEPLOYMENT_PREFIX=DEV

DATABASE_URL="postgresql://user:password@localhost:5432/openturn_db?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
# Opcionais (Redis 6+ ACL / requirepass)
REDIS_USERNAME=
REDIS_PASSWORD=
# Alternativa: se REDIS_HOST não estiver definido, REDIS_URL é usada (ex.: redis://user:pass@host:6379)
# REDIS_URL=redis://localhost:6379

# RabbitMQ (orquestração de jobs por instituição)
RABBIT_URL=amqp://guest:guest@localhost:5672

# Tempo máximo (segundos) que uma vaga rotina:inflight:z:{inst} ocupa por exeId; após isso a vaga libera se o worker cair.
ROTINA_INFLIGHT_LEASE_SEC=3600

# Relay WebSocket da webapi (equipamentos com EQPUsaAddon / Control iD via connector)
# URL completa do endpoint interno (mesmo path que o connector usa):
# WEBAPI_WS_URL=ws://127.0.0.1:8001/ws/connectors
# Ou host + porta (default path /ws/connectors, scheme ws):
# WEBAPI_WS_HOST=127.0.0.1
# WEBAPI_WS_PORT=8001
# WEBAPI_WS_SCHEME=ws
# Token igual ao RELAY_INTERNAL_TOKEN da webapi (header x-internal-token para clientes internos).
RELAY_INTERNAL_TOKEN=
