{
    "name": "@openturn/remote-ui-gateway",
    "version": "1.0.0",
    "description": "Remote UI Gateway — L7 reverse proxy for on-premise equipment UI",
    "main": "./dist/index.js",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch --onSuccess \"node dist/index.js\"",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "service:install": "node scripts/windows-service.cjs install",
        "service:uninstall": "node scripts/windows-service.cjs uninstall"
    },
    "dependencies": {
        "@prisma/client": "^5.10.2",
        "dotenv": "^16.4.5",
        "express": "^4.18.3",
        "jsonwebtoken": "^9.0.2",
        "node-windows": "^1.0.0-beta.8",
        "pino": "^8.19.0",
        "pino-http": "^9.0.0",
        "pino-pretty": "^10.3.1",
        "ws": "^8.16.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.11.24",
        "@types/ws": "^8.5.10",
        "prisma": "^5.10.2",
        "tsup": "^8.0.2",
        "typescript": "^5.3.3"
    }
}
